<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#263238">


    <ImageButton
        android:id="@+id/ibExit"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Exit"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Edit Goals"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/ibExit"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp" />


    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#FFFFFF"
        android:alpha="0.2"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />


    <TextView
        android:id="@+id/tvSavingsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Savings Goal"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/divider"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp" />


    <TextView
        android:id="@+id/saving"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R 00 000.00"
        android:textColor="#000000"
        android:textSize="20sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSavingsLabel"
        app:layout_constraintStart_toStartOf="@id/tvSavingsLabel" />


    <EditText
        android:id="@+id/editTextText3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="New Amount"
        android:inputType="numberDecimal"
        android:textColor="#000000"
        android:textSize="20sp"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="@id/saving"
        app:layout_constraintBottom_toBottomOf="@id/saving"
        app:layout_constraintStart_toEndOf="@id/saving"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="24dp" />


    <TextView
        android:id="@+id/tvDebtLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Debt Goal"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/saving"
        android:layout_marginTop="48dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp" />


    <TextView
        android:id="@+id/Debt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R 00 000.00"
        android:textColor="#000000"
        android:textSize="20sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDebtLabel"
        app:layout_constraintStart_toStartOf="@id/tvDebtLabel" />


    <EditText
        android:id="@+id/editTextText4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="New Amount"
        android:inputType="numberDecimal"
        android:textColor="#000000"
        android:textSize="20sp"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="@id/Debt"
        app:layout_constraintBottom_toBottomOf="@id/Debt"
        app:layout_constraintStart_toEndOf="@id/Debt"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="24dp" />


    <Button
        android:id="@+id/btnSetNewGoals"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Set New Goals"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:backgroundTint="#2A9D8F"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toBottomOf="@id/editTextText4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
