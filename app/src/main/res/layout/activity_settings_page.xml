<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF2F8"
    tools:context=".Settings_Page"
    android:padding="16dp">


    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#FFFFFF"
        app:cardElevation="6dp"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView23"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Settings"
                android:textColor="#2A9D8F"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <ImageButton
                android:id="@+id/ibExit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Exit"
                android:padding="8dp"
                app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:backgroundTint="#FFFFFF"
        app:cardElevation="6dp"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp"
        android:padding="16dp">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnCurrency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Change Currency"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_manage"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Change Language"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_set_as"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnBudgetReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Budget Report"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_agenda"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnEditBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Budget"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnEditCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Categories"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_sort_by_size"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnEditGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Goals"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_compass"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D9E6"
                    android:layout_marginVertical="8dp" />

                <Button
                    android:id="@+id/btnEditProfileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile Info"
                    android:textColor="#00B0F5"
                    android:textSize="18sp"
                    android:backgroundTint="#FFFFFF"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="12dp"
                    android:padding="12dp" />
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>